<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>u7midias — Gestão de Conteúdo</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
  :root {
    --bg: #0d0f0e;
    --bg2: #141714;
    --bg3: #1a1d1a;
    --bg4: #202320;
    --border: rgba(255,255,255,0.07);
    --border2: rgba(255,255,255,0.12);
    --text: #e8ebe8;
    --text2: #8a9088;
    --text3: #5a5e58;
    --green: #4caf6e;
    --green2: #2d7a3a;
    --green-dim: rgba(76,175,110,0.12);
    --green-glow: rgba(76,175,110,0.25);
    --orange: #e8834a;
    --blue: #5b9bd5;
    --pink: #d46b8a;
    --yellow: #c9a84c;
    --radius: 12px;
    --radius-sm: 8px;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Poppins', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; overflow-x: hidden; }

  /* ─── SCROLLBAR ─── */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--bg4); border-radius: 4px; }

  /* ─── INPUT BASE ─── */
  input, select, textarea {
    background: var(--bg3); border: 1px solid var(--border2); border-radius: var(--radius-sm);
    color: var(--text); font-family: 'Poppins', sans-serif; font-size: 13px;
    padding: 9px 12px; width: 100%; outline: none; transition: border-color 0.2s;
  }
  input:focus, select:focus, textarea:focus { border-color: var(--green); }
  select option { background: var(--bg3); }
  textarea { resize: vertical; min-height: 70px; }

  /* ─── LOGIN ─── */
  #loginScreen {
    display: flex; align-items: center; justify-content: center;
    min-height: 100vh; padding: 2rem;
  }
  .login-box {
    background: var(--bg2); border: 1px solid var(--border); border-radius: 20px;
    padding: 2.5rem; width: 100%; max-width: 380px;
  }
  .login-logo { font-family: 'Poppins', sans-serif; font-size: 28px; font-weight: 800; color: var(--green); margin-bottom: 6px; }
  .login-sub { font-size: 13px; color: var(--text2); margin-bottom: 2rem; }
  .login-label { font-size: 12px; color: var(--text2); margin-bottom: 5px; display: block; }
  .login-field { margin-bottom: 14px; }
  .btn-login {
    width: 100%; padding: 11px; background: var(--green); color: #fff;
    border: none; border-radius: var(--radius-sm); font-family: 'Poppins', sans-serif;
    font-size: 14px; font-weight: 600; cursor: pointer; transition: background 0.2s; margin-top: 6px;
  }
  .btn-login:hover { background: #3a9658; }
  .login-err { font-size: 12px; color: #e05e5e; margin-top: 10px; text-align: center; display: none; }

  /* ─── APP SHELL ─── */
  #appShell { display: none; flex-direction: column; min-height: 100vh; }

  /* ─── TOPBAR ─── */
  .topbar {
    display: flex; align-items: center; gap: 16px; padding: 0 1.5rem;
    height: 56px; border-bottom: 1px solid var(--border); background: var(--bg2);
    position: sticky; top: 0; z-index: 50;
  }
  .topbar-logo { font-family: 'Poppins', sans-serif; font-size: 18px; font-weight: 800; color: var(--green); letter-spacing: -0.5px; }
  .topbar-sep { width: 1px; height: 20px; background: var(--border2); }
  .topbar-title { font-size: 14px; color: var(--text2); flex: 1; }
  .topbar-user { font-size: 12px; color: var(--text3); }
  .btn-logout { background: none; border: 1px solid var(--border2); border-radius: 6px; padding: 5px 10px; color: var(--text2); font-size: 12px; cursor: pointer; font-family: 'Poppins', sans-serif; transition: all 0.15s; }
  .btn-logout:hover { border-color: var(--border2); color: var(--text); }

  /* ─── MAIN LAYOUT ─── */
  .app-body { display: flex; flex: 1; }
  .sidebar { width: 240px; border-right: 1px solid var(--border); background: var(--bg2); padding: 1.25rem 0; flex-shrink: 0; overflow-y: auto; }
  .sidebar-section { padding: 0 1rem; margin-bottom: 1.5rem; }
  .sidebar-label { font-size: 10px; font-weight: 600; color: var(--text3); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 8px; padding: 0 4px; }
  .client-item {
    display: flex; align-items: center; gap: 10px; padding: 8px 10px; border-radius: var(--radius-sm);
    cursor: pointer; transition: background 0.15s; margin-bottom: 2px;
  }
  .client-item:hover { background: var(--bg3); }
  .client-item.active { background: var(--green-dim); }
  .client-avatar {
    width: 30px; height: 30px; border-radius: 8px; display: flex; align-items: center;
    justify-content: center; font-family: 'Poppins', sans-serif; font-size: 12px; font-weight: 700;
    flex-shrink: 0;
  }
  .client-name { font-size: 13px; font-weight: 500; line-height: 1.2; }
  .client-niche { font-size: 11px; color: var(--text3); }
  .btn-new-client {
    display: flex; align-items: center; gap: 8px; padding: 8px 10px; border-radius: var(--radius-sm);
    border: 1px dashed var(--border2); background: none; color: var(--text2); font-size: 13px;
    cursor: pointer; width: 100%; font-family: 'Poppins', sans-serif; transition: all 0.15s; margin-top: 6px;
  }
  .btn-new-client:hover { border-color: var(--green); color: var(--green); }

  /* ─── CONTENT AREA ─── */
  .content { flex: 1; overflow-y: auto; padding: 1.5rem; }

  /* ─── HOME / DASHBOARD ─── */
  .home-header { margin-bottom: 2rem; }
  .home-title { font-family: 'Poppins', sans-serif; font-size: 26px; font-weight: 700; margin-bottom: 4px; }
  .home-sub { font-size: 14px; color: var(--text2); }
  .clients-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 12px; }
  .client-card {
    background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius);
    padding: 1.25rem; cursor: pointer; transition: all 0.2s; position: relative; overflow: hidden;
  }
  .client-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: var(--accent, var(--green));
  }
  .client-card:hover { border-color: var(--border2); transform: translateY(-2px); }
  .card-top { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
  .card-avatar { width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: 'Poppins', sans-serif; font-size: 16px; font-weight: 700; }
  .card-name { font-family: 'Poppins', sans-serif; font-size: 15px; font-weight: 700; }
  .card-niche { font-size: 12px; color: var(--text2); }
  .card-stats { display: flex; gap: 16px; }
  .card-stat { font-size: 12px; color: var(--text2); }
  .card-stat strong { display: block; font-size: 18px; font-weight: 500; color: var(--text); font-family: 'Poppins', sans-serif; line-height: 1.2; }
  .card-add {
    background: var(--bg2); border: 1px dashed var(--border2); border-radius: var(--radius);
    padding: 1.25rem; cursor: pointer; transition: all 0.2s;
    display: flex; align-items: center; justify-content: center; gap: 10px;
    color: var(--text2); font-size: 14px; min-height: 130px;
  }
  .card-add:hover { border-color: var(--green); color: var(--green); }

  /* ─── CLIENT VIEW ─── */
  .client-header { display: flex; align-items: center; gap: 14px; margin-bottom: 1.5rem; }
  .client-header-avatar { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-family: 'Poppins', sans-serif; font-size: 18px; font-weight: 700; }
  .client-header h1 { font-family: 'Poppins', sans-serif; font-size: 22px; font-weight: 700; }
  .client-header p { font-size: 13px; color: var(--text2); }
  .btn-edit-client { margin-left: auto; background: none; border: 1px solid var(--border2); border-radius: 6px; padding: 6px 12px; color: var(--text2); font-size: 12px; cursor: pointer; font-family: 'Poppins', sans-serif; transition: all 0.15s; }
  .btn-edit-client:hover { color: var(--text); border-color: var(--border2); }

  /* ─── TABS ─── */
  .tabs { display: flex; gap: 4px; margin-bottom: 1.5rem; border-bottom: 1px solid var(--border); padding-bottom: 0; }
  .tab-btn {
    padding: 8px 16px; background: none; border: none; color: var(--text2); font-size: 13px;
    cursor: pointer; font-family: 'Poppins', sans-serif; border-bottom: 2px solid transparent;
    margin-bottom: -1px; transition: all 0.15s;
  }
  .tab-btn:hover { color: var(--text); }
  .tab-btn.active { color: var(--green); border-bottom-color: var(--green); }

  /* ─── CALENDAR ─── */
  .month-nav { display: flex; align-items: center; gap: 10px; margin-bottom: 1rem; }
  .nav-btn { background: var(--bg3); border: 1px solid var(--border); border-radius: 6px; width: 30px; height: 30px; color: var(--text2); cursor: pointer; font-size: 16px; display: flex; align-items: center; justify-content: center; transition: all 0.15s; }
  .nav-btn:hover { border-color: var(--border2); color: var(--text); }
  .month-label { font-family: 'Poppins', sans-serif; font-size: 15px; font-weight: 600; }
  .btn-new-post { margin-left: auto; background: var(--green); color: #fff; border: none; border-radius: var(--radius-sm); padding: 7px 14px; font-size: 13px; font-weight: 500; cursor: pointer; font-family: 'Poppins', sans-serif; transition: background 0.15s; }
  .btn-new-post:hover { background: #3a9658; }
  .cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 3px; }
  .cal-head { text-align: center; font-size: 10px; font-weight: 600; color: var(--text3); padding: 4px 0 8px; text-transform: uppercase; letter-spacing: 0.06em; }
  .cal-cell {
    min-height: 80px; background: var(--bg2); border: 1px solid var(--border); border-radius: 8px;
    padding: 6px; cursor: pointer; transition: border-color 0.15s; position: relative;
  }
  .cal-cell:hover { border-color: var(--border2); }
  .cal-cell.empty { background: transparent; border-color: transparent; cursor: default; }
  .cal-cell.today { border-color: var(--green); }
  .day-num { font-size: 11px; font-weight: 500; color: var(--text3); margin-bottom: 4px; }
  .cal-cell.today .day-num { color: var(--green); font-weight: 700; }
  .post-chip { font-size: 10px; padding: 2px 5px; border-radius: 4px; margin-bottom: 2px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-weight: 500; }
  .chip-feed { background: rgba(76,175,110,0.15); color: #4caf6e; }
  .chip-story { background: rgba(232,131,74,0.15); color: #e8834a; }
  .chip-reels { background: rgba(91,155,213,0.15); color: #5b9bd5; }
  .chip-promo { background: rgba(212,107,138,0.15); color: #d46b8a; }
  .chip-tiktok { background: rgba(201,168,76,0.15); color: #c9a84c; }
  .cal-add { position: absolute; bottom: 4px; right: 4px; width: 16px; height: 16px; border-radius: 50%; background: var(--bg4); border: 1px solid var(--border2); color: var(--text3); font-size: 12px; display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.15s; cursor: pointer; }
  .cal-cell:hover .cal-add { opacity: 1; }

  /* ─── POSTS LIST ─── */
  .posts-toolbar { display: flex; align-items: center; gap: 8px; margin-bottom: 1rem; flex-wrap: wrap; }
  .filter-chip { padding: 5px 12px; border-radius: 20px; border: 1px solid var(--border); background: none; color: var(--text2); font-size: 12px; cursor: pointer; font-family: 'Poppins', sans-serif; transition: all 0.15s; }
  .filter-chip:hover { border-color: var(--border2); color: var(--text); }
  .filter-chip.active { background: var(--green-dim); border-color: var(--green); color: var(--green); }
  .post-list { display: flex; flex-direction: column; gap: 6px; }
  .post-card {
    display: flex; align-items: flex-start; gap: 12px; padding: 12px 14px;
    background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius);
    transition: border-color 0.15s;
  }
  .post-card:hover { border-color: var(--border2); }
  .post-date-col { flex-shrink: 0; width: 36px; text-align: center; }
  .post-day { font-family: 'Poppins', sans-serif; font-size: 20px; font-weight: 700; line-height: 1; }
  .post-wday { font-size: 10px; color: var(--text3); text-transform: uppercase; letter-spacing: 0.04em; }
  .post-body { flex: 1; min-width: 0; }
  .post-top { display: flex; gap: 6px; align-items: center; margin-bottom: 5px; flex-wrap: wrap; }
  .type-badge { font-size: 11px; padding: 2px 8px; border-radius: 10px; font-weight: 500; }
  .tb-feed { background: rgba(76,175,110,0.15); color: #4caf6e; }
  .tb-story { background: rgba(232,131,74,0.15); color: #e8834a; }
  .tb-reels { background: rgba(91,155,213,0.15); color: #5b9bd5; }
  .tb-promo { background: rgba(212,107,138,0.15); color: #d46b8a; }
  .tb-tiktok { background: rgba(201,168,76,0.15); color: #c9a84c; }
  .pillar-tag { font-size: 11px; padding: 2px 8px; border-radius: 10px; background: var(--bg3); color: var(--text2); }
  .post-title { font-size: 14px; font-weight: 500; margin-bottom: 3px; }
  .post-caption { font-size: 12px; color: var(--text2); line-height: 1.5; }
  .post-footer { display: flex; gap: 6px; margin-top: 8px; }
  .act-btn { font-size: 11px; padding: 4px 10px; border-radius: 6px; border: 1px solid var(--border); background: none; color: var(--text2); cursor: pointer; font-family: 'Poppins', sans-serif; transition: all 0.15s; }
  .act-btn:hover { border-color: var(--border2); color: var(--text); }
  .act-btn.del:hover { border-color: #e05e5e; color: #e05e5e; }

  /* ─── METRICS ─── */
  .metrics-form { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.25rem; margin-bottom: 1.5rem; }
  .metrics-form h3 { font-family: 'Poppins', sans-serif; font-size: 15px; font-weight: 600; margin-bottom: 1rem; }
  .metrics-grid-form { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 10px; margin-bottom: 1rem; }
  .metric-field label { display: block; font-size: 11px; color: var(--text2); margin-bottom: 4px; }
  .btn-save-metrics { background: var(--green); color: #fff; border: none; border-radius: var(--radius-sm); padding: 8px 18px; font-size: 13px; font-weight: 500; cursor: pointer; font-family: 'Poppins', sans-serif; }
  .metrics-display { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 8px; margin-bottom: 1.5rem; }
  .metric-card { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); padding: 14px; }
  .metric-platform { font-size: 10px; color: var(--text3); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 2px; }
  .metric-lbl { font-size: 12px; color: var(--text2); margin-bottom: 6px; }
  .metric-val { font-family: 'Poppins', sans-serif; font-size: 24px; font-weight: 700; line-height: 1; }
  .metric-val.green { color: var(--green); }
  .metric-val.orange { color: var(--orange); }
  .metric-val.blue { color: var(--blue); }
  .metric-sub { font-size: 11px; color: var(--text3); margin-top: 4px; }

  /* ─── GOALS ─── */
  .goals-section { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.25rem; margin-bottom: 1rem; }
  .goals-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; }
  .goals-header h3 { font-family: 'Poppins', sans-serif; font-size: 15px; font-weight: 600; }
  .btn-add-goal { background: none; border: 1px dashed var(--border2); border-radius: 6px; padding: 5px 10px; color: var(--text2); font-size: 12px; cursor: pointer; font-family: 'Poppins', sans-serif; transition: all 0.15s; }
  .btn-add-goal:hover { border-color: var(--green); color: var(--green); }
  .goal-row { display: flex; align-items: center; gap: 10px; padding: 8px 0; border-bottom: 1px solid var(--border); font-size: 13px; cursor: pointer; }
  .goal-row:last-child { border-bottom: none; }
  .goal-check { width: 18px; height: 18px; border-radius: 5px; border: 1.5px solid var(--border2); flex-shrink: 0; display: flex; align-items: center; justify-content: center; transition: all 0.15s; }
  .goal-check.done { background: var(--green); border-color: var(--green); }
  .goal-text { flex: 1; }
  .goal-text.done { text-decoration: line-through; color: var(--text3); }
  .goal-del { background: none; border: none; color: var(--text3); cursor: pointer; font-size: 14px; padding: 2px 6px; opacity: 0; transition: opacity 0.15s; }
  .goal-row:hover .goal-del { opacity: 1; }

  /* ─── MODALS ─── */
  .overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 200; align-items: center; justify-content: center; padding: 1rem; }
  .overlay.open { display: flex; }
  .modal { background: var(--bg2); border: 1px solid var(--border2); border-radius: 16px; padding: 1.5rem; width: 100%; max-width: 420px; }
  .modal h3 { font-family: 'Poppins', sans-serif; font-size: 18px; font-weight: 700; margin-bottom: 1.25rem; }
  .form-row { margin-bottom: 12px; }
  .form-row label { display: block; font-size: 12px; color: var(--text2); margin-bottom: 5px; }
  .modal-actions { display: flex; gap: 8px; justify-content: flex-end; margin-top: 1.25rem; }
  .btn-cancel { padding: 8px 16px; border-radius: var(--radius-sm); border: 1px solid var(--border2); background: none; color: var(--text2); font-size: 13px; cursor: pointer; font-family: 'Poppins', sans-serif; transition: all 0.15s; }
  .btn-cancel:hover { color: var(--text); }
  .btn-save { padding: 8px 18px; border-radius: var(--radius-sm); background: var(--green); color: #fff; border: none; font-size: 13px; font-weight: 500; cursor: pointer; font-family: 'Poppins', sans-serif; transition: background 0.15s; }
  .btn-save:hover { background: #3a9658; }

  /* ─── TOAST ─── */
  .toast { position: fixed; bottom: 1.5rem; right: 1.5rem; background: var(--bg3); border: 1px solid var(--border2); border-radius: var(--radius-sm); padding: 10px 16px; font-size: 13px; color: var(--text); z-index: 500; opacity: 0; transform: translateY(8px); transition: all 0.25s; pointer-events: none; }
  .toast.show { opacity: 1; transform: translateY(0); }
  .toast.ok { border-color: var(--green); }
  .toast.err { border-color: #e05e5e; color: #e05e5e; }

  /* ─── LOADING ─── */
  .loading { display: flex; align-items: center; justify-content: center; padding: 3rem; color: var(--text3); font-size: 14px; }
  .spinner { width: 20px; height: 20px; border: 2px solid var(--border2); border-top-color: var(--green); border-radius: 50%; animation: spin 0.7s linear infinite; margin-right: 10px; }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ─── EMPTY STATE ─── */
  .empty { text-align: center; padding: 3rem 1rem; color: var(--text3); }
  .empty-icon { font-size: 36px; margin-bottom: 10px; }
  .empty p { font-size: 14px; }

  /* ─── LEGEND ─── */
  .legend { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 1rem; }
  .legend-item { display: flex; align-items: center; gap: 5px; font-size: 11px; color: var(--text2); }
  .legend-dot { width: 8px; height: 8px; border-radius: 3px; }

  /* ─── MONTH PICKER ─── */
  .month-tabs { display: flex; gap: 4px; margin-bottom: 1rem; flex-wrap: wrap; }
  .month-tab { padding: 4px 10px; border-radius: 6px; border: 1px solid var(--border); background: none; font-size: 12px; color: var(--text2); cursor: pointer; font-family: 'Poppins', sans-serif; transition: all 0.15s; }
  .month-tab.active { background: var(--green-dim); border-color: var(--green); color: var(--green); }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 640px) {
    .sidebar { display: none; }
    .content { padding: 1rem; }
    .cal-cell { min-height: 60px; }
  }
</style>
</head>
<body>

<!-- LOGIN -->
<div id="loginScreen">
  <div class="login-box">
    <div class="login-logo">u7midias</div>
    <div class="login-sub">Gestão de conteúdo para clientes</div>
    <div class="login-field">
      <label class="login-label">E-mail</label>
      <input type="email" id="loginEmail" placeholder="seu@email.com" />
    </div>
    <div class="login-field">
      <label class="login-label">Senha</label>
      <input type="password" id="loginPass" placeholder="••••••••" onkeydown="if(event.key==='Enter')doLogin()" />
    </div>
    <button class="btn-login" onclick="doLogin()">Entrar</button>
    <div class="login-err" id="loginErr">E-mail ou senha incorretos.</div>
  </div>
</div>

<!-- APP -->
<div id="appShell">
  <div class="topbar">
    <div class="topbar-logo">u7midias</div>
    <div class="topbar-sep"></div>
    <div class="topbar-title" id="topTitle">Dashboard</div>
    <div class="topbar-user" id="topUser"></div>
    <button class="btn-logout" onclick="doLogout()">Sair</button>
  </div>
  <div class="app-body">
    <!-- SIDEBAR -->
    <div class="sidebar">
      <div class="sidebar-section">
        <div class="sidebar-label">Clientes</div>
        <div id="sidebarList"></div>
        <button class="btn-new-client" onclick="openNewClientModal()">＋ Novo cliente</button>
      </div>
    </div>
    <!-- CONTENT -->
    <div class="content" id="mainContent">
      <div class="loading"><div class="spinner"></div>Carregando...</div>
    </div>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<!-- MODAL: NOVO/EDITAR CLIENTE -->
<div class="overlay" id="clientModal" onclick="closeOnOverlay(event,'clientModal')">
  <div class="modal">
    <h3 id="clientModalTitle">Novo cliente</h3>
    <div class="form-row"><label>Nome do cliente</label><input type="text" id="cName" placeholder="Ex: Horta em Casa" /></div>
    <div class="form-row"><label>Nicho / segmento</label><input type="text" id="cNiche" placeholder="Ex: Hortifrúti local" /></div>
    <div class="form-row"><label>@ Instagram</label><input type="text" id="cInsta" placeholder="@perfil" /></div>
    <div class="form-row"><label>@ TikTok</label><input type="text" id="cTiktok" placeholder="@perfil" /></div>
    <div class="form-row"><label>Cor (hex)</label><input type="color" id="cColor" value="#4caf6e" style="padding:4px;height:36px;cursor:pointer" /></div>
    <input type="hidden" id="cId" />
    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeModal('clientModal')">Cancelar</button>
      <button class="btn-save" onclick="saveClient()">Salvar</button>
    </div>
  </div>
</div>

<!-- MODAL: NOVO/EDITAR POST -->
<div class="overlay" id="postModal" onclick="closeOnOverlay(event,'postModal')">
  <div class="modal">
    <h3 id="postModalTitle">Novo post</h3>
    <div class="form-row"><label>Data</label><input type="date" id="pDate" /></div>
    <div class="form-row"><label>Plataforma</label>
      <select id="pPlatform">
        <option value="instagram">Instagram</option>
        <option value="tiktok">TikTok</option>
        <option value="whatsapp">WhatsApp</option>
      </select>
    </div>
    <div class="form-row"><label>Tipo</label>
      <select id="pType">
        <option value="feed">Feed</option>
        <option value="story">Story</option>
        <option value="reels">Reels</option>
        <option value="tiktok">TikTok Vídeo</option>
        <option value="promo">Promoção</option>
      </select>
    </div>
    <div class="form-row"><label>Pilar de conteúdo</label><input type="text" id="pPillar" placeholder="Ex: Frescor & Qualidade" /></div>
    <div class="form-row"><label>Título / ideia</label><input type="text" id="pTitle" placeholder="Descreva o post" /></div>
    <div class="form-row"><label>Legenda / roteiro</label><textarea id="pCaption" placeholder="Escreva aqui..."></textarea></div>
    <input type="hidden" id="pId" />
    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeModal('postModal')">Cancelar</button>
      <button class="btn-save" onclick="savePost()">Salvar</button>
    </div>
  </div>
</div>

<!-- MODAL: META/OBJETIVO -->
<div class="overlay" id="goalModal" onclick="closeOnOverlay(event,'goalModal')">
  <div class="modal">
    <h3>Novo objetivo</h3>
    <div class="form-row"><label>Objetivo do mês</label><input type="text" id="gText" placeholder="Ex: Alcançar 5.000 seguidores" /></div>
    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeModal('goalModal')">Cancelar</button>
      <button class="btn-save" onclick="saveGoal()">Salvar</button>
    </div>
  </div>
</div>

<script>
const SUPABASE_URL = 'https://ftpaslpccsjenbatunwl.supabase.co';
const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZ0cGFzbHBjY3NqZW5iYXRudXdsIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUwNzMxNTUsImV4cCI6MjA5MDY0OTE1NX0.bhl45H4BCGzHJatUYPPsuBallvKTXl2ROnthdDM126s';
const sb = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

const MONTHS = ['Janeiro','Fevereiro','Março','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];
const DAYS = ['Dom','Seg','Ter','Qua','Qui','Sex','Sáb'];
const COLORS = ['#4caf6e','#e8834a','#5b9bd5','#d46b8a','#c9a84c','#8b6fd4','#4cb8af','#d45b5b'];

let state = { clients: [], activeClient: null, activeTab: 'calendar', year: new Date().getFullYear(), month: new Date().getMonth(), posts: [], goals: [], metrics: null, filter: 'todos', user: null };

// ─── AUTH ───
async function doLogin() {
  const email = document.getElementById('loginEmail').value.trim();
  const pass = document.getElementById('loginPass').value;
  const err = document.getElementById('loginErr');
  err.style.display = 'none';
  const { data, error } = await sb.auth.signInWithPassword({ email, password: pass });
  if (error) { err.style.display = 'block'; return; }
  state.user = data.user;
  document.getElementById('loginScreen').style.display = 'none';
  document.getElementById('appShell').style.display = 'flex';
  document.getElementById('topUser').textContent = email;
  await loadClients();
  renderHome();
}

async function doLogout() {
  await sb.auth.signOut();
  location.reload();
}

// ─── CLIENTS ───
async function loadClients() {
  const { data } = await sb.from('clients').select('*').order('created_at');
  state.clients = data || [];
  renderSidebar();
}

function renderSidebar() {
  const list = document.getElementById('sidebarList');
  list.innerHTML = '';
  state.clients.forEach(c => {
    const item = document.createElement('div');
    item.className = 'client-item' + (state.activeClient?.id === c.id ? ' active' : '');
    const letter = c.name.charAt(0).toUpperCase();
    const color = c.color || COLORS[0];
    item.innerHTML = `
      <div class="client-avatar" style="background:${color}22;color:${color}">${letter}</div>
      <div><div class="client-name">${c.name}</div><div class="client-niche">${c.niche||''}</div></div>`;
    item.onclick = () => selectClient(c);
    list.appendChild(item);
  });
}

async function selectClient(c) {
  state.activeClient = c;
  state.activeTab = 'calendar';
  state.filter = 'todos';
  document.getElementById('topTitle').textContent = c.name;
  renderSidebar();
  showLoading();
  await Promise.all([loadPosts(), loadGoals(), loadMetrics()]);
  renderClientView();
}

function renderHome() {
  state.activeClient = null;
  document.getElementById('topTitle').textContent = 'Dashboard';
  renderSidebar();
  const content = document.getElementById('mainContent');
  const now = new Date();
  content.innerHTML = `
    <div class="home-header">
      <div class="home-title">Olá! 👋</div>
      <div class="home-sub">${state.clients.length} cliente${state.clients.length !== 1 ? 's' : ''} cadastrado${state.clients.length !== 1 ? 's' : ''}. Selecione um para gerenciar.</div>
    </div>
    <div class="clients-grid" id="homeGrid"></div>`;
  const grid = document.getElementById('homeGrid');
  state.clients.forEach(c => {
    const color = c.color || COLORS[0];
    const card = document.createElement('div');
    card.className = 'client-card';
    card.style.setProperty('--accent', color);
    card.innerHTML = `
      <div class="card-top">
        <div class="card-avatar" style="background:${color}22;color:${color}">${c.name.charAt(0)}</div>
        <div><div class="card-name">${c.name}</div><div class="card-niche">${c.niche||'—'}</div></div>
      </div>
      <div class="card-stats">
        <div class="card-stat"><strong>${c.instagram||'—'}</strong>Instagram</div>
        <div class="card-stat"><strong>${c.tiktok||'—'}</strong>TikTok</div>
      </div>`;
    card.onclick = () => selectClient(c);
    grid.appendChild(card);
  });
  const addCard = document.createElement('div');
  addCard.className = 'card-add';
  addCard.innerHTML = `<span style="font-size:20px">＋</span> Novo cliente`;
  addCard.onclick = openNewClientModal;
  grid.appendChild(addCard);
}

function openNewClientModal(client) {
  document.getElementById('clientModalTitle').textContent = client ? 'Editar cliente' : 'Novo cliente';
  document.getElementById('cId').value = client?.id || '';
  document.getElementById('cName').value = client?.name || '';
  document.getElementById('cNiche').value = client?.niche || '';
  document.getElementById('cInsta').value = client?.instagram || '';
  document.getElementById('cTiktok').value = client?.tiktok || '';
  document.getElementById('cColor').value = client?.color || '#4caf6e';
  openModal('clientModal');
}

async function saveClient() {
  const id = document.getElementById('cId').value;
  const data = {
    name: document.getElementById('cName').value.trim(),
    niche: document.getElementById('cNiche').value.trim(),
    instagram: document.getElementById('cInsta').value.trim(),
    tiktok: document.getElementById('cTiktok').value.trim(),
    color: document.getElementById('cColor').value,
  };
  if (!data.name) { toast('Informe o nome do cliente.', 'err'); return; }
  let result;
  if (id) {
    result = await sb.from('clients').update(data).eq('id', id).select().single();
  } else {
    result = await sb.from('clients').insert(data).select().single();
  }
  if (result.error) { toast('Erro ao salvar: ' + result.error.message, 'err'); return; }
  closeModal('clientModal');
  toast('Cliente salvo!', 'ok');
  await loadClients();
  if (id && state.activeClient?.id == id) { state.activeClient = result.data; renderClientView(); }
  else renderHome();
}

// ─── POSTS ───
async function loadPosts() {
  const { data } = await sb.from('posts').select('*').eq('client_id', state.activeClient.id).order('date');
  state.posts = data || [];
}

async function savePost() {
  const id = document.getElementById('pId').value;
  const data = {
    client_id: state.activeClient.id,
    date: document.getElementById('pDate').value,
    platform: document.getElementById('pPlatform').value,
    type: document.getElementById('pType').value,
    pillar: document.getElementById('pPillar').value.trim(),
    title: document.getElementById('pTitle').value.trim(),
    caption: document.getElementById('pCaption').value.trim(),
  };
  if (!data.date || !data.title) { toast('Informe data e título.', 'err'); return; }
  let result;
  if (id) {
    result = await sb.from('posts').update(data).eq('id', id);
  } else {
    result = await sb.from('posts').insert(data);
  }
  if (result.error) { toast('Erro: ' + result.error.message, 'err'); return; }
  closeModal('postModal');
  toast('Post salvo!', 'ok');
  await loadPosts();
  renderClientView();
}

async function deletePost(id) {
  if (!confirm('Remover este post?')) return;
  await sb.from('posts').delete().eq('id', id);
  state.posts = state.posts.filter(p => p.id !== id);
  toast('Post removido.', 'ok');
  renderClientView();
}

function openPostModal(dateStr) {
  document.getElementById('postModalTitle').textContent = 'Novo post';
  document.getElementById('pId').value = '';
  document.getElementById('pDate').value = dateStr || '';
  document.getElementById('pTitle').value = '';
  document.getElementById('pCaption').value = '';
  document.getElementById('pPillar').value = '';
  openModal('postModal');
}

// ─── GOALS ───
async function loadGoals() {
  const { data } = await sb.from('goals').select('*').eq('client_id', state.activeClient.id).order('created_at');
  state.goals = data || [];
}

async function saveGoal() {
  const text = document.getElementById('gText').value.trim();
  if (!text) return;
  const { error } = await sb.from('goals').insert({ client_id: state.activeClient.id, text, done: false });
  if (error) { toast('Erro: ' + error.message, 'err'); return; }
  closeModal('goalModal');
  toast('Objetivo adicionado!', 'ok');
  await loadGoals();
  renderClientView();
}

async function toggleGoal(id, done) {
  await sb.from('goals').update({ done: !done }).eq('id', id);
  state.goals = state.goals.map(g => g.id === id ? { ...g, done: !done } : g);
  renderClientView();
}

async function deleteGoal(id) {
  await sb.from('goals').delete().eq('id', id);
  state.goals = state.goals.filter(g => g.id !== id);
  renderClientView();
}

// ─── METRICS ───
async function loadMetrics() {
  const now = new Date();
  const { data } = await sb.from('metrics')
    .select('*')
    .eq('client_id', state.activeClient.id)
    .eq('year', now.getFullYear())
    .eq('month', now.getMonth() + 1)
    .maybeSingle();
  state.metrics = data;
}

async function saveMetrics() {
  const now = new Date();
  const fields = ['ig_seguidores','ig_alcance','ig_impressoes','ig_engajamento','ig_salvamentos','ig_compartilhamentos','tt_seguidores','tt_views','tt_conclusao','tt_compartilhamentos','tt_fyp','wa_contatos','wa_taxa_resposta','wa_enviadas'];
  const data = { client_id: state.activeClient.id, year: now.getFullYear(), month: now.getMonth() + 1 };
  fields.forEach(f => {
    const el = document.getElementById('m_' + f);
    if (el) data[f] = el.value ? parseFloat(el.value) : null;
  });
  if (state.metrics?.id) {
    await sb.from('metrics').update(data).eq('id', state.metrics.id);
  } else {
    await sb.from('metrics').insert(data);
  }
  toast('Métricas salvas!', 'ok');
  await loadMetrics();
  renderClientView();
}

// ─── RENDER CLIENT VIEW ───
function renderClientView() {
  const c = state.activeClient;
  const color = c.color || COLORS[0];
  const content = document.getElementById('mainContent');
  content.innerHTML = `
    <div class="client-header">
      <div class="client-header-avatar" style="background:${color}22;color:${color}">${c.name.charAt(0)}</div>
      <div><h1>${c.name}</h1><p>${c.niche||''} ${c.instagram ? '· ' + c.instagram : ''}</p></div>
      <button class="btn-edit-client" onclick="openNewClientModal(state.activeClient)">Editar</button>
    </div>
    <div class="tabs">
      <button class="tab-btn ${state.activeTab==='calendar'?'active':''}" onclick="switchTab('calendar')">Calendário</button>
      <button class="tab-btn ${state.activeTab==='posts'?'active':''}" onclick="switchTab('posts')">Posts</button>
      <button class="tab-btn ${state.activeTab==='metrics'?'active':''}" onclick="switchTab('metrics')">Métricas</button>
      <button class="tab-btn ${state.activeTab==='goals'?'active':''}" onclick="switchTab('goals')">Objetivos</button>
    </div>
    <div id="tabContent"></div>`;
  renderTab();
}

function switchTab(tab) {
  state.activeTab = tab;
  renderClientView();
}

function renderTab() {
  const tc = document.getElementById('tabContent');
  if (state.activeTab === 'calendar') renderCalendarTab(tc);
  else if (state.activeTab === 'posts') renderPostsTab(tc);
  else if (state.activeTab === 'metrics') renderMetricsTab(tc);
  else if (state.activeTab === 'goals') renderGoalsTab(tc);
}

// ─── CALENDAR TAB ───
function renderCalendarTab(container) {
  const y = state.year, m = state.month;
  container.innerHTML = `
    <div class="month-nav">
      <button class="nav-btn" onclick="changeMonth(-1)">‹</button>
      <span class="month-label">${MONTHS[m]} ${y}</span>
      <button class="nav-btn" onclick="changeMonth(1)">›</button>
      <button class="btn-new-post" onclick="openPostModal()">+ Novo post</button>
    </div>
    <div class="legend">
      <div class="legend-item"><div class="legend-dot" style="background:#4caf6e"></div>Feed</div>
      <div class="legend-item"><div class="legend-dot" style="background:#e8834a"></div>Story</div>
      <div class="legend-item"><div class="legend-dot" style="background:#5b9bd5"></div>Reels</div>
      <div class="legend-item"><div class="legend-dot" style="background:#d46b8a"></div>Promo</div>
      <div class="legend-item"><div class="legend-dot" style="background:#c9a84c"></div>TikTok</div>
    </div>
    <div class="cal-grid" id="calGrid"></div>`;

  const grid = document.getElementById('calGrid');
  DAYS.forEach(d => { const h = document.createElement('div'); h.className = 'cal-head'; h.textContent = d; grid.appendChild(h); });
  const first = new Date(y, m, 1).getDay();
  const days = new Date(y, m + 1, 0).getDate();
  const today = new Date();
  for (let i = 0; i < first; i++) { const e = document.createElement('div'); e.className = 'cal-cell empty'; grid.appendChild(e); }
  for (let d = 1; d <= days; d++) {
    const dateStr = `${y}-${String(m+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const cell = document.createElement('div');
    cell.className = 'cal-cell' + (today.getFullYear()===y && today.getMonth()===m && today.getDate()===d ? ' today' : '');
    const num = document.createElement('div'); num.className = 'day-num'; num.textContent = d; cell.appendChild(num);
    const dayPosts = state.posts.filter(p => p.date === dateStr);
    dayPosts.slice(0, 3).forEach(p => {
      const chip = document.createElement('div');
      chip.className = `post-chip chip-${p.type}`;
      chip.textContent = p.title.length > 20 ? p.title.slice(0,20)+'…' : p.title;
      cell.appendChild(chip);
    });
    if (dayPosts.length > 3) {
      const more = document.createElement('div'); more.className = 'post-chip'; more.style.cssText = 'background:var(--bg4);color:var(--text3)'; more.textContent = `+${dayPosts.length-3}`; cell.appendChild(more);
    }
    const addBtn = document.createElement('button');
    addBtn.className = 'cal-add'; addBtn.textContent = '+';
    addBtn.onclick = (e) => { e.stopPropagation(); openPostModal(dateStr); };
    cell.appendChild(addBtn);
    grid.appendChild(cell);
  }
}

function changeMonth(dir) {
  state.month += dir;
  if (state.month > 11) { state.month = 0; state.year++; }
  if (state.month < 0) { state.month = 11; state.year--; }
  renderTab();
}

// ─── POSTS TAB ───
function renderPostsTab(container) {
  const types = ['todos','feed','story','reels','tiktok','promo'];
  const labels = { todos:'Todos', feed:'Feed', story:'Story', reels:'Reels', tiktok:'TikTok', promo:'Promoção' };
  const filtered = state.filter === 'todos' ? state.posts : state.posts.filter(p => p.type === state.filter);
  const sorted = [...filtered].sort((a, b) => a.date.localeCompare(b.date));

  container.innerHTML = `
    <div class="posts-toolbar">
      ${types.map(t => `<button class="filter-chip${state.filter===t?' active':''}" onclick="setFilter('${t}')">${labels[t]} (${t==='todos'?state.posts.length:state.posts.filter(p=>p.type===t).length})</button>`).join('')}
      <button class="btn-new-post" style="margin-left:auto" onclick="openPostModal()">+ Novo post</button>
    </div>
    <div class="post-list" id="postList"></div>`;

  const list = document.getElementById('postList');
  if (!sorted.length) { list.innerHTML = '<div class="empty"><div class="empty-icon">📭</div><p>Nenhum post encontrado.</p></div>'; return; }
  sorted.forEach(p => {
    const d = new Date(p.date + 'T00:00:00');
    const card = document.createElement('div'); card.className = 'post-card';
    card.innerHTML = `
      <div class="post-date-col"><div class="post-day">${d.getDate()}</div><div class="post-wday">${DAYS[d.getDay()]}</div></div>
      <div class="post-body">
        <div class="post-top">
          <span class="type-badge tb-${p.type}">${p.type.charAt(0).toUpperCase()+p.type.slice(1)}</span>
          ${p.platform ? `<span class="pillar-tag">${p.platform}</span>` : ''}
          ${p.pillar ? `<span class="pillar-tag">${p.pillar}</span>` : ''}
        </div>
        <div class="post-title">${p.title}</div>
        ${p.caption ? `<div class="post-caption">${p.caption}</div>` : ''}
        <div class="post-footer">
          <button class="act-btn del" onclick="deletePost(${p.id})">Remover</button>
        </div>
      </div>`;
    list.appendChild(card);
  });
}

function setFilter(f) { state.filter = f; renderTab(); }

// ─── METRICS TAB ───
