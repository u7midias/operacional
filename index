        ${fld('tt_fyp','Alcance FYP',m.tt_fyp)}
      </div>
      <div style="font-size:12px;color:var(--text2);margin-bottom:1rem;font-weight:600;margin-top:0.5rem">WhatsApp Business</div>
      <div class="metrics-grid-form">
        ${fld('wa_contatos','Contatos ativos',m.wa_contatos)}
        ${fld('wa_taxa_resposta','Taxa de resposta (%)',m.wa_taxa_resposta)}
        ${fld('wa_enviadas','Mensagens enviadas',m.wa_enviadas)}
      </div>
      <button class="btn-save-metrics" onclick="saveMetrics()">Salvar métricas</button>
    </div>`;
}

// ─── GOALS TAB ───
function renderGoalsTab(container) {
  container.innerHTML = `
    <div class="goals-section">
      <div class="goals-header">
        <h3>Objetivos do mês</h3>
        <button class="btn-add-goal" onclick="openModal('goalModal')">+ Adicionar</button>
      </div>
      <div id="goalsList"></div>
    </div>`;
  const list = document.getElementById('goalsList');
  if (!state.goals.length) { list.innerHTML = '<div class="empty" style="padding:1rem"><p>Nenhum objetivo cadastrado.</p></div>'; return; }
  state.goals.forEach(g => {
    const row = document.createElement('div'); row.className = 'goal-row';
    row.innerHTML = `
      <div class="goal-check${g.done?' done':''}">
        ${g.done ? '<svg width="10" height="10" viewBox="0 0 10 10"><polyline points="1.5,5 4,7.5 8.5,2.5" fill="none" stroke="#fff" stroke-width="1.5"/></svg>' : ''}
      </div>
      <div class="goal-text${g.done?' done':''}">${g.text}</div>
      <button class="goal-del" onclick="event.stopPropagation();deleteGoal(${g.id})">✕</button>`;
    row.onclick = () => toggleGoal(g.id, g.done);
    list.appendChild(row);
  });
}

// ─── UTILS ───
function showLoading() {
  document.getElementById('mainContent').innerHTML = '<div class="loading"><div class="spinner"></div>Carregando...</div>';
}

function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }
function closeOnOverlay(e, id) { if (e.target.id === id) closeModal(id); }

let toastTimer;
function toast(msg, type = 'ok') {
  const el = document.getElementById('toast');
  el.textContent = msg; el.className = `toast ${type} show`;
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => el.classList.remove('show'), 2800);
}

// ─── INIT: check session ───
(async () => {
  const { data: { session } } = await sb.auth.getSession();
  if (session) {
    state.user = session.user;
    document.getElementById('loginScreen').style.display = 'none';
    document.getElementById('appShell').style.display = 'flex';
    document.getElementById('topUser').textContent = session.user.email;
    await loadClients();
    renderHome();
  }
})();
