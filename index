      ${card('Instagram','Alcance', m.ig_alcance, 'blue')}
      ${card('Instagram','Engajamento %', m.ig_engajamento != null ? m.ig_engajamento+'%' : null, 'orange')}
      ${card('Instagram','Salvamentos', m.ig_salvamentos)}
      ${card('Instagram','Compartilhamentos', m.ig_compartilhamentos)}
      ${card('TikTok','Seguidores', m.tt_seguidores, 'green')}
      ${card('TikTok','Visualizações', m.tt_views, 'blue')}
      ${card('TikTok','Conclusão %', m.tt_conclusao != null ? m.tt_conclusao+'%' : null, 'orange')}
