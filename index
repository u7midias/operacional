      ${card('WhatsApp','Contatos ativos', m.wa_contatos, 'green')}
      ${card('WhatsApp','Taxa resposta %', m.wa_taxa_resposta != null ? m.wa_taxa_resposta+'%' : null, 'orange')}
      ${card('WhatsApp','Msg enviadas', m.wa_enviadas)}
    </div>
    <div class="metrics-form">
      <h3>Atualizar métricas — ${MONTHS[new Date().getMonth()]} ${new Date().getFullYear()}</h3>
      <div style="font-size:12px;color:var(--text2);margin-bottom:1rem;font-weight:600">Instagram</div>
      <div class="metrics-grid-form">
        ${fld('ig_seguidores','Seguidores',m.ig_seguidores)}
        ${fld('ig_alcance','Alcance',m.ig_alcance)}
        ${fld('ig_impressoes','Impressões',m.ig_impressoes)}
        ${fld('ig_engajamento','Engajamento (%)',m.ig_engajamento)}
        ${fld('ig_salvamentos','Salvamentos',m.ig_salvamentos)}
        ${fld('ig_compartilhamentos','Compartilhamentos',m.ig_compartilhamentos)}
      </div>
      <div style="font-size:12px;color:var(--text2);margin-bottom:1rem;font-weight:600;margin-top:0.5rem">TikTok</div>
